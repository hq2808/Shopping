				{
					"name": "User Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"Saved JWT Token successfully: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
